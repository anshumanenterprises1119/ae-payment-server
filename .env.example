# ─── PhonePe Credentials ──────────────────────────────────────
# PhonePe Dashboard se milenge: https://www.phonepe.com/business-solutions/

PHONEPE_CLIENT_ID=your_client_id_here
PHONEPE_CLIENT_SECRET=your_client_secret_here
