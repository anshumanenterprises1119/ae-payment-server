# PhonePe Gateway — Environment Variables
# ⚠️ Ye file .gitignore mein add karo — kabhi GitHub pe push mat karna

# ─── PhonePe Credentials ──────────────────────────────────────────
# PhonePe Dashboard se milenge: https://business.phonepe.com/developer-settings/api-keys
PHONEPE_CLIENT_ID=your_client_id_here
PHONEPE_CLIENT_SECRET=your_client_secret_here
PHONEPE_SALT_KEY=099eb0cd-02cf-4e2a-8aca-3e6c6aff0399

# ─── Environment ──────────────────────────────────────────────────
# Sandbox ke liye: true  | Production ke liye: false
PHONEPE_SANDBOX=true

# ─── Webhook Auth (PhonePe Dashboard → Webhooks mein set karo) ────
PHONEPE_WEBHOOK_USERNAME=your_webhook_username
PHONEPE_WEBHOOK_PASSWORD=your_webhook_password

# ─── URLs (Render deploy ke baad update karo) ─────────────────────
# Aapka Render server URL (example):
CALLBACK_URL=https://ae-payment-server.onrender.com/callback

# Frontend URLs (default theek hain, change mat karo)
SUCCESS_URL=https://anshumanenterprises.online/payment-success.html
FAILURE_URL=https://anshumanenterprises.online/payment-failure.html

# ─── Server ───────────────────────────────────────────────────────
PORT=3001
